---
import Boton from "./BotonDifuminado.astro";
const {inicial} = Astro.props
---

<ul class="lg:flex lg:gap-x-2 w-full justify-center my-4 py-2" id={inicial}>
    <div class="md:flex gap-x-2 md:w-full lg:w-fit justify-center">
        <div class="flex gap-x-2 md:w-fit w-full justify-center">
            <Boton ciencia="matemáticas" direccion="/articulos/matematicas"/>
            <Boton ciencia="biología" direccion="/articulos/biologia"/>
            <Boton ciencia="geología" direccion="/articulos/geologia"/>
        </div>
        <div class="flex gap-x-2 md:w-fit w-full justify-center my-3 md:m-0">
            <Boton ciencia="física" direccion="/articulos/fisica"/>
            <Boton ciencia="química" direccion="/articulos/quimica"/>
            <Boton ciencia="tecnología" direccion="/articulos/tecnologia"/>
        </div>
    </div>
    <div class="flex gap-x-2 w-full lg:w-fit justify-center md:mt-3 lg:m-0">
        <Boton ciencia="programación" direccion="/articulos/programacion"/>
        <Boton ciencia="científicos" direccion="/articulos/cientificos"/>
    </div>
</ul>